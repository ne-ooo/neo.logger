{
  "name": "@lpm.dev/neo.logger",
  "version": "1.0.0",
  "description": "Zero-dependency production logger - Fast, modern alternative to winston and pino",
  "author": "neo",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    ".lpm",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "logger",
    "logging",
    "winston",
    "pino",
    "bunyan",
    "zero-dependency",
    "typescript",
    "structured-logging",
    "json-logger",
    "console-logger",
    "esm",
    "tree-shakeable"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ne-ooo/neo.logger"
  },
  "homepage": "https://github.com/ne-ooo/neo.logger#readme",
  "bugs": {
    "url": "https://github.com/ne-ooo/neo.logger/issues"
  },
  "peerDependencies": {
    "@lpm.dev/neo.colors": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@lpm.dev/neo.colors": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lpm.dev/neo.colors": "workspace:*",
    "@types/node": "^20.11.0",
    "pino": "^10.3.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1",
    "winston": "^3.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
